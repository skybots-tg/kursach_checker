# === Обязательные для продакшена ===
JWT_SECRET=your-strong-random-secret-here
ADMIN_JWT_SECRET=your-strong-admin-secret-here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kursach
REDIS_URL=redis://localhost:6379/0
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=your_bot_username

# === Приложение ===
APP_BASE_URL=https://your-domain.com
APP_HOST=0.0.0.0
APP_PORT=8343
APP_RELOAD=false
DEBUG=false

# === CORS (через запятую, или пустое = APP_BASE_URL) ===
ALLOWED_ORIGINS=

# === Лимиты ===
MAX_UPLOAD_MB=20
JWT_EXPIRE_HOURS=24
ADMIN_JWT_EXPIRE_HOURS=8
TELEGRAM_AUTH_MAX_AGE_SEC=86400

# === Бонусы ===
# Приветственный бонус новым пользователям (0 — отключено).
# Можно переопределить в админке: «Настройки → Приветственный бонус».
WELCOME_BONUS_AMOUNT=3

# === Оплата Prodamus ===
PRODAMUS_SECRET_KEY=your-prodamus-secret
PRODAMUS_PAYFORM_URL=https://yourshop.payform.ru
PRODAMUS_TIMEOUT_SEC=30

# === Конвертация DOC -> DOCX (опционально) ===
# DOC_TO_DOCX_CONVERTER=soffice --headless --convert-to docx --outdir "{outdir}" "{input}"

# === БД ===
INIT_DB_ON_STARTUP=false
